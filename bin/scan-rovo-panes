#!/usr/bin/env bash
#
# scan-rovo-panes - detect Rovo Dev CLI panes and report them to Herdr.
#
# Invoked by the plugin manifest as an action and on lifecycle events
# (pane.created/focused/moved/exited, tab.created). For every pane it:
#
#   1. checks whether Rovo Dev is the foreground process,
#   2. if Rovo's event hooks are already actively reporting for that pane,
#      trusts them completely and skips re-deriving state from output (see
#      pane_hook_active in herdr-lib.sh) - this is a strictly more reliable
#      signal than screen-scraping, so hooked panes are left alone,
#   3. otherwise, classifies state from recent output and reports the agent
#      (the bootstrap path for panes without active hooks yet),
#   4. if a pane we previously tracked is no longer Rovo, resets it to idle
#      and forgets its hook marker (hooks cannot self-report a process that
#      has already exited).
#
# Safe to run repeatedly; it is idempotent.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=./herdr-lib.sh
source "$SCRIPT_DIR/herdr-lib.sh"

require_jq || exit 1

TRACKED="$(tracked_file)"
touch "$TRACKED" 2>/dev/null || true

# Panes we mark as Rovo during this run.
declare -a current_rovo=()

while IFS= read -r pane_id; do
  [ -n "$pane_id" ] || continue

  if pane_is_rovo "$pane_id"; then
    if pane_hook_active "$pane_id"; then
      # Hooks are actively firing for this pane; they are authoritative and
      # more reliable than screen-scraping. Leave their last-reported state
      # untouched and only track the pane so the exit-reset logic below still
      # applies if Rovo later exits without a clean on_session_end.
      current_rovo+=("$pane_id")
      echo "skip $pane_id (hook-active, trusting last hook report)"
    else
      state="$(classify_state "$pane_id")"
      custom_status="$(derive_custom_status "$pane_id")"
      if report_agent "$pane_id" "$state" "$custom_status"; then
        current_rovo+=("$pane_id")
        echo "reported $pane_id state=$state ${custom_status:+status=$custom_status}"
      fi
    fi
  fi
done < <(list_pane_ids)

# Reset any previously-tracked pane that is no longer running Rovo. This covers
# panes where Rovo exited or was replaced by another foreground process.
if [ -s "$TRACKED" ]; then
  while IFS= read -r old_pane; do
    [ -n "$old_pane" ] || continue
    still=0
    for p in "${current_rovo[@]:-}"; do
      [ "$p" = "$old_pane" ] && still=1 && break
    done
    if [ "$still" -eq 0 ]; then
      report_agent "$old_pane" "idle" "exited" \
        && echo "reset $old_pane -> idle (exited)"
      clear_pane_hooked "$old_pane"
    fi
  done < "$TRACKED"
fi

# Persist the current set of Rovo panes for the next run.
printf '%s\n' "${current_rovo[@]:-}" | sed '/^$/d' > "$TRACKED"

exit 0
