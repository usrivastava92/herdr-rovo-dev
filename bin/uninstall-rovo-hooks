#!/usr/bin/env bash
#
# uninstall-rovo-hooks - remove the Herdr bridge from Rovo Dev's event hooks.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=./herdr-lib.sh
source "$SCRIPT_DIR/herdr-lib.sh"

HOOK_MARKER="rovo-herdr-hook"
YQ_BIN=""

# Resolve the Rovo config for both the new Rovo CLI (~/.rovo/config.yml) and the
# legacy Rovo Dev CLI (~/.rovodev/config.yml). See rovo_config_file in
# herdr-lib.sh for the full resolution order and env overrides.
config_file() {
  rovo_config_file
}

if command -v yq >/dev/null 2>&1; then
  YQ_BIN="$(command -v yq)"
else
  for candidate in /opt/homebrew/bin/yq /usr/local/bin/yq; do
    if [ -x "$candidate" ]; then
      YQ_BIN="$candidate"
      break
    fi
  done
fi

if [ -z "$YQ_BIN" ]; then
  echo "herdr-rovo-dev: yq is required to uninstall Rovo hooks" >&2
  exit 1
fi

config="$(config_file)"
if [ ! -f "$config" ]; then
  echo "herdr-rovo-dev: Rovo Dev config not found: $config" >&2
  exit 1
fi

backup="${config}.before-herdr-rovo-dev-uninstall.$(date +%Y%m%d%H%M%S)"
cp -p "$config" "$backup"

MARKER="$HOOK_MARKER" "$YQ_BIN" -i \
  '(.eventHooks.events[].commands) |= ((. // []) | map(select(((.command // "") | contains(strenv(MARKER))) | not)))' \
  "$config"

echo "Removed Herdr Rovo hooks from $config"
echo "Backup: $backup"
