#!/usr/bin/env bash
#
# install-rovo-hooks - add the Herdr bridge to Rovo Dev's event hooks.
#
# Runs in two modes:
#   manual (default): invoked on-demand via the "Install Rovo event hooks"
#                      action. Missing prerequisites (yq, Rovo config) are
#                      hard errors (exit 1) since the user explicitly asked
#                      for this to happen.
#   --auto:            invoked automatically as a [[build]] step right after
#                      the plugin is installed. Missing prerequisites are NOT
#                      fatal here - yq is an optional dependency (unlike
#                      bash/jq/grep/sed) and the Rovo config may not exist yet
#                      if Rovo hasn't been run once on this machine. In that
#                      case we skip quietly (exit 0) so plugin install still
#                      succeeds, and tell the user how to install hooks later
#                      via the manual action once the prerequisite is met.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=./herdr-lib.sh
source "$SCRIPT_DIR/herdr-lib.sh"

AUTO=0
if [ "${1:-}" = "--auto" ]; then
  AUTO=1
  shift
fi

HOOK_MARKER="rovo-herdr-hook"
HOOK_CMD=""
YQ_BIN=""
EVENTS=(
  on_session_start
  on_user_prompt
  on_tool_start
  on_tool_permission
  on_tool_end
  on_complete
  on_error
  on_session_end
)

# Resolve the Rovo config for both the new Rovo CLI (~/.rovo/config.yml) and the
# legacy Rovo Dev CLI (~/.rovodev/config.yml). See rovo_config_file in
# herdr-lib.sh for the full resolution order and env overrides.
config_file() {
  rovo_config_file
}

# Report a missing prerequisite. In manual mode this is a hard error (exit
# 1); in --auto mode it is a quiet, non-fatal skip (exit 0) so plugin install
# still succeeds - the user can install hooks later via the manual action.
skip_or_fail() {
  if [ "$AUTO" -eq 1 ]; then
    printf 'herdr-rovo-dev: %s\n' "$1"
    echo "herdr-rovo-dev: skipping automatic Rovo hook install for now."
    echo "herdr-rovo-dev: run the \"Install Rovo event hooks\" action any time to enable it once ready."
    exit 0
  else
    printf 'herdr-rovo-dev: %s\n' "$1" >&2
    exit 1
  fi
}

require_yq() {
  if command -v yq >/dev/null 2>&1; then
    YQ_BIN="$(command -v yq)"
    return 0
  fi

  local candidate
  for candidate in /opt/homebrew/bin/yq /usr/local/bin/yq; do
    if [ -x "$candidate" ]; then
      YQ_BIN="$candidate"
      return 0
    fi
  done

  return 1
}

ensure_event() {
  local event="$1" config="$2"
  if ! EVENT="$event" "$YQ_BIN" '.eventHooks.events[] | select(.name == strenv(EVENT)) | .name' "$config" \
    | grep -qx "$event"; then
    EVENT="$event" "$YQ_BIN" -i '.eventHooks.events += [{"name": strenv(EVENT), "commands": []}]' "$config"
  fi
}

install_for_event() {
  local event="$1" config="$2"
  ensure_event "$event" "$config"
  EVENT="$event" CMD="$HOOK_CMD" "$YQ_BIN" -i \
    '(.eventHooks.events[] | select(.name == strenv(EVENT)).commands) += [{"command": strenv(CMD)}]' \
    "$config"
}

# Copy the stable launcher script to a location next to the resolved Rovo
# config, and register that copy as the hook command. This is preferred over
# registering the plugin's own bin/rovo-herdr-hook path directly, because
# Herdr relocates a freshly-installed plugin out of an ephemeral temp checkout
# into a content-hashed directory (and re-hashes again on every upgrade), so
# any path captured at install time eventually stops existing. The launcher
# resolves the plugin's current location itself, at fire-time, via Herdr's
# public `plugin list` API - see rovo-herdr-hook-launcher for details.
#
# NOTE: this sets the global HOOK_CMD directly rather than "returning" via a
# command substitution ($(...)). skip_or_fail must be able to terminate the
# whole script (exit 0 in --auto mode, exit 1 otherwise); calling it from
# inside a command substitution would only terminate that subshell, silently
# swallowing the failure and leaving HOOK_CMD empty.
install_launcher() {
  local config="$1"
  local launcher_src="$SCRIPT_DIR/rovo-herdr-hook-launcher"
  if [ ! -f "$launcher_src" ]; then
    skip_or_fail "missing bundled launcher: $launcher_src"
  fi

  local config_dir launcher_dir launcher_dest
  config_dir="$(dirname "$config")"
  launcher_dir="$config_dir/hooks/herdr-managed"
  launcher_dest="$launcher_dir/rovo-herdr-hook"

  # Defensive guard: never persist a hook command that lives under an
  # ephemeral install temp dir, or anywhere outside the config's own
  # directory tree. This is the exact class of bug that made the old
  # $SCRIPT_DIR-captured path go stale within seconds of a fresh GitHub
  # install (see docs/rovo-status-fix-plan.md, Bug 1).
  case "$launcher_dest" in
    *"/.tmp-install-"*)
      skip_or_fail "refusing to record an ephemeral install path as the Rovo hook command: $launcher_dest"
      ;;
  esac
  case "$launcher_dest" in
    "$config_dir"/*) ;;
    *)
      skip_or_fail "refusing to record a hook command outside the Rovo config directory: $launcher_dest"
      ;;
  esac

  # Route filesystem failures through skip_or_fail rather than letting `set -e`
  # abort with a bare non-zero exit. In --auto (build) mode that keeps the
  # contract that a best-effort hook install never fails the plugin install
  # (skip_or_fail exits 0 there); in manual mode it still surfaces a clear
  # error and exits 1.
  mkdir -p "$launcher_dir" \
    || skip_or_fail "could not create launcher directory: $launcher_dir"
  cp -p "$launcher_src" "$launcher_dest" \
    || skip_or_fail "could not install launcher: $launcher_dest"
  chmod +x "$launcher_dest" \
    || skip_or_fail "could not make launcher executable: $launcher_dest"

  HOOK_CMD="$launcher_dest"
}

main() {
  if ! require_yq; then
    skip_or_fail "yq is required to install Rovo hooks (install it with: brew install yq)"
  fi

  local config
  config="$(config_file)"
  if [ ! -f "$config" ]; then
    skip_or_fail "Rovo config not found: $config"
  fi

  install_launcher "$config"

  local backup="${config}.before-herdr-rovo-dev.$(date +%Y%m%d%H%M%S)"
  cp -p "$config" "$backup"

  "$YQ_BIN" -i '.eventHooks = (.eventHooks // {}) | .eventHooks.events = (.eventHooks.events // [])' "$config"

  MARKER="$HOOK_MARKER" "$YQ_BIN" -i \
    '(.eventHooks.events[].commands) |= ((. // []) | map(select(((.command // "") | contains(strenv(MARKER))) | not)))' \
    "$config"

  local event
  for event in "${EVENTS[@]}"; do
    install_for_event "$event" "$config"
  done

  echo "Installed Herdr Rovo hooks into $config"
  echo "Backup: $backup"
  echo "Restart any running Rovo CLI / Rovo Dev CLI sessions to pick up the new hooks."
}

main "$@"
