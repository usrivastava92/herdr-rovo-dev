#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -lt 1 ] || [ "$#" -gt 2 ]; then
  printf 'usage: %s VERSION [MANIFEST]\n' "$0" >&2
  exit 2
fi

version=$1
manifest=${2:-herdr-plugin.toml}
tmp="${manifest}.tmp.$$"

if ! printf '%s\n' "$version" | grep -Eq '^[0-9]+[.][0-9]+[.][0-9]+(-[0-9A-Za-z.-]+)?([+][0-9A-Za-z.-]+)?$'; then
  printf 'invalid semver: %s\n' "$version" >&2
  exit 2
fi

trap 'rm -f "$tmp"' EXIT

awk -v version="$version" '
  BEGIN { updated = 0 }
  /^version[[:space:]]*=/ {
    print "version = \"" version "\""
    updated = 1
    next
  }
  { print }
  END {
    if (!updated) {
      exit 2
    }
  }
' "$manifest" > "$tmp"

mv "$tmp" "$manifest"
trap - EXIT
